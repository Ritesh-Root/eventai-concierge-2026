{
  "name": "event-ai-concierge",
  "version": "1.0.0",
  "description": "AI-powered concierge for physical event attendees — schedule, navigation, networking, accessibility, and Q&A via Gemini 2.5 Flash",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Ritesh-Root/eventai-concierge-2026.git"
  },
  "homepage": "https://event-ai-concierge-520503380800.us-central1.run.app",
  "bugs": {
    "url": "https://github.com/Ritesh-Root/eventai-concierge-2026/issues"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "node --watch server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "validate": "npm run lint && npm test"
  },
  "keywords": [
    "event",
    "ai",
    "concierge",
    "gemini",
    "google-ai",
    "streaming",
    "vision",
    "accessibility",
    "pwa",
    "cloud-run"
  ],
  "author": "Sunmount Solutions",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "branches": 70,
        "functions": 80,
        "statements": 80
      }
    }
  }
}
