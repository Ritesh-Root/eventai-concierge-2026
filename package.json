{
  "name": "event-ai-concierge",
  "version": "1.0.0",
  "description": "AI-powered concierge for physical event attendees — schedule, navigation, networking, accessibility, and Q&A via Gemini 2.5 Flash",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "event",
    "ai",
    "concierge",
    "gemini",
    "accessibility"
  ],
  "author": "Sunmount Solutions",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "branches": 60,
        "functions": 70,
        "statements": 70
      }
    }
  }
}
